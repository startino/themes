---
prism:
  version: "^0.1.0"
filename: "dist/startino-{{ flavor.identifier }}.conf"
matrix:
  - flavor
---
# Startino Themes — {{ flavor.name }} {{ flavor.emoji }}
# Generated by prism. Do not edit by hand.

background              {{ base | hex }}
foreground              {{ text | hex }}
cursor                  {{ rosewater | hex }}
cursor_text_color       {{ base | hex }}
selection_background    {{ surface2 | hex }}
selection_foreground    {{ text | hex }}
url_color               {{ blue | hex }}

# ANSI colors
color0   {{ flavor.ansiColors.black.normal.hex }}
color1   {{ flavor.ansiColors.red.normal.hex }}
color2   {{ flavor.ansiColors.green.normal.hex }}
color3   {{ flavor.ansiColors.yellow.normal.hex }}
color4   {{ flavor.ansiColors.blue.normal.hex }}
color5   {{ flavor.ansiColors.magenta.normal.hex }}
color6   {{ flavor.ansiColors.cyan.normal.hex }}
color7   {{ flavor.ansiColors.white.normal.hex }}
color8   {{ flavor.ansiColors.black.bright.hex }}
color9   {{ flavor.ansiColors.red.bright.hex }}
color10  {{ flavor.ansiColors.green.bright.hex }}
color11  {{ flavor.ansiColors.yellow.bright.hex }}
color12  {{ flavor.ansiColors.blue.bright.hex }}
color13  {{ flavor.ansiColors.magenta.bright.hex }}
color14  {{ flavor.ansiColors.cyan.bright.hex }}
color15  {{ flavor.ansiColors.white.bright.hex }}

# Window borders
active_border_color     {{ green | hex }}
inactive_border_color   {{ overlay0 | hex }}
bell_border_color       {{ peach | hex }}

# Tab bar
active_tab_background   {{ green | hex }}
active_tab_foreground   {{ crust | hex }}
inactive_tab_background {{ surface0 | hex }}
inactive_tab_foreground {{ subtext0 | hex }}
tab_bar_background      {{ crust | hex }}

# Marks
mark1_background        {{ green | hex }}
mark1_foreground        {{ crust | hex }}
mark2_background        {{ pink | hex }}
mark2_foreground        {{ crust | hex }}
mark3_background        {{ peach | hex }}
mark3_foreground        {{ crust | hex }}
