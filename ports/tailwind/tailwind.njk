---
prism:
  version: "^0.1.0"
filename: "dist/startino.css"
matrix: []
---
/*! Startino Themes v0.1.0 — generated by prism. Do not edit by hand. */

{% for f in flavors %}
{% if loop.last %}
:root,
[data-flavor="{{ f.identifier }}"] {
{% else %}
[data-flavor="{{ f.identifier }}"] {
{% endif %}
  /* accents */
  --color-rosewater: {{ f.colors.rosewater | hex }};
  --color-flamingo:  {{ f.colors.flamingo  | hex }};
  --color-pink:      {{ f.colors.pink      | hex }};
  --color-mauve:     {{ f.colors.mauve     | hex }};
  --color-red:       {{ f.colors.red       | hex }};
  --color-maroon:    {{ f.colors.maroon    | hex }};
  --color-peach:     {{ f.colors.peach     | hex }};
  --color-yellow:    {{ f.colors.yellow    | hex }};
  --color-green:     {{ f.colors.green     | hex }};
  --color-teal:      {{ f.colors.teal      | hex }};
  --color-sky:       {{ f.colors.sky       | hex }};
  --color-sapphire:  {{ f.colors.sapphire  | hex }};
  --color-blue:      {{ f.colors.blue      | hex }};
  --color-lavender:  {{ f.colors.lavender  | hex }};
  /* neutrals */
  --color-text:      {{ f.colors.text      | hex }};
  --color-subtext-1: {{ f.colors.subtext1  | hex }};
  --color-subtext-0: {{ f.colors.subtext0  | hex }};
  --color-overlay-2: {{ f.colors.overlay2  | hex }};
  --color-overlay-1: {{ f.colors.overlay1  | hex }};
  --color-overlay-0: {{ f.colors.overlay0  | hex }};
  --color-surface-2: {{ f.colors.surface2  | hex }};
  --color-surface-1: {{ f.colors.surface1  | hex }};
  --color-surface-0: {{ f.colors.surface0  | hex }};
  --color-base:      {{ f.colors.base      | hex }};
  --color-mantle:    {{ f.colors.mantle    | hex }};
  --color-crust:     {{ f.colors.crust     | hex }};
  /* brand + semantic aliases */
  --color-primary:   {{ f.colors.green     | hex }};
  --color-secondary: {{ f.colors.pink      | hex }};
  --color-error:     {{ f.colors.red       | hex }};
  --color-warning:   {{ f.colors.peach     | hex }};
  --color-info:      {{ f.colors.blue      | hex }};
  --color-success:   {{ f.colors.green     | hex }};
  --color-link:      {{ f.colors.blue      | hex }};
}
{% endfor %}
