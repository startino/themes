---
prism:
  version: "^0.1.0"
filename: "dist/startino-{{ flavor.identifier }}.config"
matrix:
  - flavor
---
# Startino Themes — {{ flavor.name }} {{ flavor.emoji }}
# Generated by prism. Do not edit by hand.
#
# Drop-in mako config — settings + colors. Copy or symlink as
# ~/.config/mako/config. Mako has no theme-import mechanism, so the
# whole config is templated; tweak settings (timeout etc.) by editing
# the source template at ports/mako/mako.njk.

default-timeout=5000

background-color={{ base | hex }}
text-color={{ text | hex }}
border-color={{ green | hex }}
progress-color=over {{ surface0 | hex }}

[urgency=high]
border-color={{ peach | hex }}
