---
prism:
  version: "^0.1.0"
filename: "dist/startino-{{ flavor.identifier }}.css"
matrix:
  - flavor
---
/* Startino Themes — {{ flavor.name }} {{ flavor.emoji }} | generated by prism */

/* All 26 palette roles */
@define-color rosewater  {{ rosewater | hex }};
@define-color flamingo   {{ flamingo | hex }};
@define-color pink       {{ pink | hex }};
@define-color mauve      {{ mauve | hex }};
@define-color red        {{ red | hex }};
@define-color maroon     {{ maroon | hex }};
@define-color peach      {{ peach | hex }};
@define-color yellow     {{ yellow | hex }};
@define-color green      {{ green | hex }};
@define-color teal       {{ teal | hex }};
@define-color sky        {{ sky | hex }};
@define-color sapphire   {{ sapphire | hex }};
@define-color blue       {{ blue | hex }};
@define-color lavender   {{ lavender | hex }};
@define-color text       {{ text | hex }};
@define-color subtext1   {{ subtext1 | hex }};
@define-color subtext0   {{ subtext0 | hex }};
@define-color overlay2   {{ overlay2 | hex }};
@define-color overlay1   {{ overlay1 | hex }};
@define-color overlay0   {{ overlay0 | hex }};
@define-color surface2   {{ surface2 | hex }};
@define-color surface1   {{ surface1 | hex }};
@define-color surface0   {{ surface0 | hex }};
@define-color base       {{ base | hex }};
@define-color mantle     {{ mantle | hex }};
@define-color crust      {{ crust | hex }};

/* Brand aliases — mint primary, pink secondary */
@define-color accent     {{ green | hex }};
@define-color primary    {{ green | hex }};
@define-color secondary  {{ pink | hex }};
