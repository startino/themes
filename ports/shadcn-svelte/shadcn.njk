---
prism:
  version: "^0.1.0"
filename: "dist/startino-{{ flavor.identifier }}.css"
matrix:
  - flavor
---
/* Startino Themes — {{ flavor.name }} {{ flavor.emoji }} | generated by prism, do not edit by hand */

:root {
  --background: oklch({{ base | oklch_tuple }});
  --foreground: oklch({{ text | oklch_tuple }});
  --card: oklch({{ mantle | oklch_tuple }});
  --card-foreground: oklch({{ text | oklch_tuple }});
  --popover: oklch({{ surface0 | oklch_tuple }});
  --popover-foreground: oklch({{ text | oklch_tuple }});
  --primary: oklch({{ green | oklch_tuple }});
  --primary-foreground: oklch({{ crust | oklch_tuple }});
  --secondary: oklch({{ pink | oklch_tuple }});
  --secondary-foreground: oklch({{ crust | oklch_tuple }});
  --muted: oklch({{ surface1 | oklch_tuple }});
  --muted-foreground: oklch({{ subtext0 | oklch_tuple }});
  --accent: oklch({{ surface2 | oklch_tuple }});
  --accent-foreground: oklch({{ text | oklch_tuple }});
  --destructive: oklch({{ red | oklch_tuple }});
  --destructive-foreground: oklch({{ crust | oklch_tuple }});
  --border: oklch({{ overlay0 | oklch_tuple }});
  --input: oklch({{ surface0 | oklch_tuple }});
  --ring: oklch({{ green | oklch_tuple }});
  --chart-1: oklch({{ green | oklch_tuple }});
  --chart-2: oklch({{ pink | oklch_tuple }});
  --chart-3: oklch({{ blue | oklch_tuple }});
  --chart-4: oklch({{ peach | oklch_tuple }});
  --chart-5: oklch({{ mauve | oklch_tuple }});
  --radius: 0.625rem;
  --sidebar: oklch({{ mantle | oklch_tuple }});
  --sidebar-foreground: oklch({{ text | oklch_tuple }});
  --sidebar-primary: oklch({{ green | oklch_tuple }});
  --sidebar-primary-foreground: oklch({{ crust | oklch_tuple }});
  --sidebar-accent: oklch({{ surface1 | oklch_tuple }});
  --sidebar-accent-foreground: oklch({{ text | oklch_tuple }});
  --sidebar-border: oklch({{ overlay0 | oklch_tuple }});
  --sidebar-ring: oklch({{ green | oklch_tuple }});
}
