---
prism:
  version: "^0.1.0"
filename: "dist/startino.lua"
matrix: []
---
-- Startino Themes — color_overrides for catppuccin/nvim. Generated by prism.
-- Do not edit by hand. Re-run `bun compiler/prism.ts --port nvim`.
--
-- Usage in your plugin spec:
--   {
--     "catppuccin/nvim",
--     opts = {
--       flavour = "mocha", -- maps to Neptune
--       color_overrides = require("startino"),
--       integrations = { ... },
--     },
--   }
--
-- Catppuccin slot names are kept for plugin compatibility. The hex each
-- slot emits is Startino's value, not Catppuccin's — see the Startino
-- style guide §7. Specifically: `mauve` collapses to `pink` (secondary),
-- `blue` is brand teal, `lavender` is sage. Don't trust the slot name
-- as a value contract; trust this file as the source of truth.
--
-- Flavor pairing: latte ← Mercury, frappe ← Mars, macchiato ← Jupiter,
-- mocha ← Neptune (brand anchor).

return {
{% set pair = { 'latte': 'mercury', 'frappe': 'mars', 'macchiato': 'jupiter', 'mocha': 'neptune' } %}
{% for catFlavor, startinoId in pair %}
  {{ catFlavor }} = {
    rosewater = "{{ flavorsById[startinoId].colors.rosewater.hex }}",
    flamingo  = "{{ flavorsById[startinoId].colors.flamingo.hex }}",
    pink      = "{{ flavorsById[startinoId].colors.pink.hex }}",
    mauve     = "{{ flavorsById[startinoId].colors.mauve.hex }}",
    red       = "{{ flavorsById[startinoId].colors.red.hex }}",
    maroon    = "{{ flavorsById[startinoId].colors.maroon.hex }}",
    peach     = "{{ flavorsById[startinoId].colors.peach.hex }}",
    yellow    = "{{ flavorsById[startinoId].colors.yellow.hex }}",
    green     = "{{ flavorsById[startinoId].colors.green.hex }}",
    teal      = "{{ flavorsById[startinoId].colors.teal.hex }}",
    sky       = "{{ flavorsById[startinoId].colors.sky.hex }}",
    sapphire  = "{{ flavorsById[startinoId].colors.sapphire.hex }}",
    blue      = "{{ flavorsById[startinoId].colors.blue.hex }}",
    lavender  = "{{ flavorsById[startinoId].colors.lavender.hex }}",
    text      = "{{ flavorsById[startinoId].colors.text.hex }}",
    subtext1  = "{{ flavorsById[startinoId].colors.subtext1.hex }}",
    subtext0  = "{{ flavorsById[startinoId].colors.subtext0.hex }}",
    overlay2  = "{{ flavorsById[startinoId].colors.overlay2.hex }}",
    overlay1  = "{{ flavorsById[startinoId].colors.overlay1.hex }}",
    overlay0  = "{{ flavorsById[startinoId].colors.overlay0.hex }}",
    surface2  = "{{ flavorsById[startinoId].colors.surface2.hex }}",
    surface1  = "{{ flavorsById[startinoId].colors.surface1.hex }}",
    surface0  = "{{ flavorsById[startinoId].colors.surface0.hex }}",
    base      = "{{ flavorsById[startinoId].colors.base.hex }}",
    mantle    = "{{ flavorsById[startinoId].colors.mantle.hex }}",
    crust     = "{{ flavorsById[startinoId].colors.crust.hex }}",
  },
{% endfor %}
}
