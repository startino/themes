palette = 3={{ flavor.ansiColors.yellow.normal.hex }}
palette = 4={{ flavor.ansiColors.blue.normal.hex }}
palette = 5={{ flavor.ansiColors.magenta.normal.hex }}
palette = 6={{ flavor.ansiColors.cyan.normal.hex }}
palette = 7={{ flavor.ansiColors.white.normal.hex }}
palette = 8={{ flavor.ansiColors.black.bright.hex }}
palette = 9={{ flavor.ansiColors.red.bright.hex }}
palette = 10={{ flavor.ansiColors.green.bright.hex }}
palette = 11={{ flavor.ansiColors.yellow.bright.hex }}
palette = 12={{ flavor.ansiColors.blue.bright.hex }}
palette = 13={{ flavor.ansiColors.magenta.bright.hex }}
palette = 14={{ flavor.ansiColors.cyan.bright.hex }}
