---
prism:
  version: "^0.1.0"
filename: "dist/catppuccin_{{ flavor.identifier }}_tmux.conf"
matrix:
  - flavor
---
# vim:set ft=tmux:

# --> Startino ({{ flavor.identifier | upper_first }})
# Catppuccin tmux plugin flavor file — drop into the plugin's themes/ directory.
# Generated by prism. Do not edit by hand.
set -ogq @thm_bg "{{ flavor.colors.base | hex }}"
set -ogq @thm_fg "{{ flavor.colors.text | hex }}"

# Accent colors
set -ogq @thm_rosewater "{{ flavor.colors.rosewater | hex }}"
set -ogq @thm_flamingo  "{{ flavor.colors.flamingo  | hex }}"
set -ogq @thm_pink      "{{ flavor.colors.pink      | hex }}"
set -ogq @thm_mauve     "{{ flavor.colors.mauve     | hex }}"
set -ogq @thm_red       "{{ flavor.colors.red       | hex }}"
set -ogq @thm_maroon    "{{ flavor.colors.maroon    | hex }}"
set -ogq @thm_peach     "{{ flavor.colors.peach     | hex }}"
set -ogq @thm_yellow    "{{ flavor.colors.yellow    | hex }}"
set -ogq @thm_green     "{{ flavor.colors.green     | hex }}"
set -ogq @thm_teal      "{{ flavor.colors.teal      | hex }}"
set -ogq @thm_sky       "{{ flavor.colors.sky       | hex }}"
set -ogq @thm_sapphire  "{{ flavor.colors.sapphire  | hex }}"
set -ogq @thm_blue      "{{ flavor.colors.blue      | hex }}"
set -ogq @thm_lavender  "{{ flavor.colors.lavender  | hex }}"

# Surfaces and overlays
set -ogq @thm_subtext_1 "{{ flavor.colors.subtext1 | hex }}"
set -ogq @thm_subtext_0 "{{ flavor.colors.subtext0 | hex }}"
set -ogq @thm_overlay_2 "{{ flavor.colors.overlay2 | hex }}"
set -ogq @thm_overlay_1 "{{ flavor.colors.overlay1 | hex }}"
set -ogq @thm_overlay_0 "{{ flavor.colors.overlay0 | hex }}"
set -ogq @thm_surface_2 "{{ flavor.colors.surface2 | hex }}"
set -ogq @thm_surface_1 "{{ flavor.colors.surface1 | hex }}"
set -ogq @thm_surface_0 "{{ flavor.colors.surface0 | hex }}"
set -ogq @thm_mantle    "{{ flavor.colors.mantle   | hex }}"
set -ogq @thm_crust     "{{ flavor.colors.crust    | hex }}"
