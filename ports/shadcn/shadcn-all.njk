---
prism:
  version: "^0.1.0"
filename: "dist/startino.css"
matrix: []
---
/* Startino Themes — all flavors via [data-flavor]. Generated by prism. */

{# Default = Neptune (applies when no data-flavor attribute is set) #}
:root {
  --background: oklch({{ flavorsById.neptune.colors.base | oklch_tuple }});
  --foreground: oklch({{ flavorsById.neptune.colors.text | oklch_tuple }});
  --card: oklch({{ flavorsById.neptune.colors.mantle | oklch_tuple }});
  --card-foreground: oklch({{ flavorsById.neptune.colors.text | oklch_tuple }});
  --popover: oklch({{ flavorsById.neptune.colors.surface0 | oklch_tuple }});
  --popover-foreground: oklch({{ flavorsById.neptune.colors.text | oklch_tuple }});
  --primary: oklch({{ flavorsById.neptune.colors.green | oklch_tuple }});
  --primary-foreground: oklch({{ flavorsById.neptune.colors.crust | oklch_tuple }});
  --secondary: oklch({{ flavorsById.neptune.colors.pink | oklch_tuple }});
  --secondary-foreground: oklch({{ flavorsById.neptune.colors.crust | oklch_tuple }});
  --muted: oklch({{ flavorsById.neptune.colors.surface1 | oklch_tuple }});
  --muted-foreground: oklch({{ flavorsById.neptune.colors.subtext0 | oklch_tuple }});
  --accent: oklch({{ flavorsById.neptune.colors.surface2 | oklch_tuple }});
  --accent-foreground: oklch({{ flavorsById.neptune.colors.text | oklch_tuple }});
  --destructive: oklch({{ flavorsById.neptune.colors.red | oklch_tuple }});
  --destructive-foreground: oklch({{ flavorsById.neptune.colors.crust | oklch_tuple }});
  --border: oklch({{ flavorsById.neptune.colors.overlay0 | oklch_tuple }});
  --input: oklch({{ flavorsById.neptune.colors.surface0 | oklch_tuple }});
  --ring: oklch({{ flavorsById.neptune.colors.green | oklch_tuple }});
  --chart-1: oklch({{ flavorsById.neptune.colors.green | oklch_tuple }});
  --chart-2: oklch({{ flavorsById.neptune.colors.pink | oklch_tuple }});
  --chart-3: oklch({{ flavorsById.neptune.colors.blue | oklch_tuple }});
  --chart-4: oklch({{ flavorsById.neptune.colors.peach | oklch_tuple }});
  --chart-5: oklch({{ flavorsById.neptune.colors.mauve | oklch_tuple }});
  --radius: 0.625rem;
  --sidebar: oklch({{ flavorsById.neptune.colors.mantle | oklch_tuple }});
  --sidebar-foreground: oklch({{ flavorsById.neptune.colors.text | oklch_tuple }});
  --sidebar-primary: oklch({{ flavorsById.neptune.colors.green | oklch_tuple }});
  --sidebar-primary-foreground: oklch({{ flavorsById.neptune.colors.crust | oklch_tuple }});
  --sidebar-accent: oklch({{ flavorsById.neptune.colors.surface1 | oklch_tuple }});
  --sidebar-accent-foreground: oklch({{ flavorsById.neptune.colors.text | oklch_tuple }});
  --sidebar-border: oklch({{ flavorsById.neptune.colors.overlay0 | oklch_tuple }});
  --sidebar-ring: oklch({{ flavorsById.neptune.colors.green | oklch_tuple }});
}

{# Per-flavor overrides — source order beats :root so attribute wins #}
{%- for f in flavors %}
[data-flavor="{{ f.identifier }}"] {
  --background: oklch({{ f.colors.base | oklch_tuple }});
  --foreground: oklch({{ f.colors.text | oklch_tuple }});
  --card: oklch({{ f.colors.mantle | oklch_tuple }});
  --card-foreground: oklch({{ f.colors.text | oklch_tuple }});
  --popover: oklch({{ f.colors.surface0 | oklch_tuple }});
  --popover-foreground: oklch({{ f.colors.text | oklch_tuple }});
  --primary: oklch({{ f.colors.green | oklch_tuple }});
  --primary-foreground: oklch({{ f.colors.crust | oklch_tuple }});
  --secondary: oklch({{ f.colors.pink | oklch_tuple }});
  --secondary-foreground: oklch({{ f.colors.crust | oklch_tuple }});
  --muted: oklch({{ f.colors.surface1 | oklch_tuple }});
  --muted-foreground: oklch({{ f.colors.subtext0 | oklch_tuple }});
  --accent: oklch({{ f.colors.surface2 | oklch_tuple }});
  --accent-foreground: oklch({{ f.colors.text | oklch_tuple }});
  --destructive: oklch({{ f.colors.red | oklch_tuple }});
  --destructive-foreground: oklch({{ f.colors.crust | oklch_tuple }});
  --border: oklch({{ f.colors.overlay0 | oklch_tuple }});
  --input: oklch({{ f.colors.surface0 | oklch_tuple }});
  --ring: oklch({{ f.colors.green | oklch_tuple }});
  --chart-1: oklch({{ f.colors.green | oklch_tuple }});
  --chart-2: oklch({{ f.colors.pink | oklch_tuple }});
  --chart-3: oklch({{ f.colors.blue | oklch_tuple }});
  --chart-4: oklch({{ f.colors.peach | oklch_tuple }});
  --chart-5: oklch({{ f.colors.mauve | oklch_tuple }});
  --radius: 0.625rem;
  --sidebar: oklch({{ f.colors.mantle | oklch_tuple }});
  --sidebar-foreground: oklch({{ f.colors.text | oklch_tuple }});
  --sidebar-primary: oklch({{ f.colors.green | oklch_tuple }});
  --sidebar-primary-foreground: oklch({{ f.colors.crust | oklch_tuple }});
  --sidebar-accent: oklch({{ f.colors.surface1 | oklch_tuple }});
  --sidebar-accent-foreground: oklch({{ f.colors.text | oklch_tuple }});
  --sidebar-border: oklch({{ f.colors.overlay0 | oklch_tuple }});
  --sidebar-ring: oklch({{ f.colors.green | oklch_tuple }});
}
{% endfor %}
